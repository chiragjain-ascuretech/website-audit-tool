{
  "name": "website-audit-tool",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n web,api,worker \"npm run dev -w apps/web\" \"npm run dev -w apps/api\" \"npm run dev:worker -w apps/api\"",
    "build": "npm run build -ws --if-present",
    "lint": "npm run lint -ws --if-present"
  },
  "devDependencies": {
    "concurrently": "*",
    "tsx": "*",
    "typescript": "*"
  },
  "keywords": [],
